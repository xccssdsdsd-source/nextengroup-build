b-12 md:pt-32 md:pb-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-4xl md:text-5xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"AI dla firm — co warto wiedzieć przed wdrożeniem\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-lg leading-[1.7] text-[#374151]\\\",\\\"children\\\":\\\"Praktyczne wyjaśnienia, które pomogą Ci zrozumieć, jak automatyzacja i agenci AI mogą wspierać Twój biznes.\\\"}]]}]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Czym jest automatyzacja AI dla firmy?\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-6 text-[#6b7280] leading-[1.7]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Automatyzacja AI to połączenie narzędzi sztucznej inteligencji z procesami biznesowymi Twojej firmy. Zamiast ręcznie odpowiadać na maile, wysyłać przypomnienia, kwalifikować leady czy generować dokumenty — robią to za Ciebie zautomatyzowane systemy. To nie o zastępowaniu ludzi, ale o uwolnieniu Twojego zespołu od powtarzających się zadań.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Praktyczne przykłady: automatyczne odpowiedzi na najczęstsze pytania klientów, wysyłanie e-maili uzupełnionych danymi z systemu CRM, generowanie ofert na podstawie parametrów, sortowanie i klasyfikowanie zapytań. Każda z tych czynności, jeśli powtarza się codziennie, jest idealnym kandydatem do automatyzacji.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"W Getbuild zawsze zaczynamy od analizy — nie szukamy gotowych rozwiązań, ale rozumiemy dokładnie, jak pracuje Twoja firma, gdzie marnuje się czas i gdzie automatyzacja przyniesie największą korzyść.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Rezultat? Mniej błędów, szybsza obsługa klientów, więcej czasu dla Twojego zespołu na pracę, która rzeczywiście tworzy wartość.\\\"}]]}]]}]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Czym jest agent AI i czym różni się od zwykłej automatyzacji?\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-6 text-[#6b7280] leading-[1.7]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Agent AI to bardziej zaawansowany system — nie tylko wykonuje zadania, ale także podejmuje decyzje, działa niezależnie i potrafi obsługiwać wieloetapowe procesy. Agent pracuje 24/7, uczy się z każdą interakcją i dostosowuje swoje działania do kontekstu.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"W przeciwieństwie do prostej automatyzacji (np. wysłanie mejla po złożeniu zamówienia), agent AI może: przeprowadzić rozmowę z potencjalnym klientem, odpowiedzieć na zmieniające się pytania, samodzielnie kwalifikować leady, zaproponować rozwiązania, a w razie potrzeby eskalować sprawę do człowieka.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Praktyczne przykłady agentów AI: agent obsługujący zapytania klientów przez chat na stronie, agent sprzedażowy, który prowadzi rozmowę i umawia spotkania, agent analizy danych, który monitoruje metryki biznesowe i wysyła codzienne raporty.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Agent to inwestycja na dłużej — im więcej z nim pracuje Twoja firma, tym lepiej się uczy i tym bardziej staje się dostosowany do Twoich procesów.\\\"}]]}]]}]}],\\\"$Ld\\\",\\\"$Le\\\",\\\"$Lf\\\",\\\"$L10\\\",\\\"$L11\\\",\\\"$L12\\\",\\\"$L13\\\",\\\"$L14\\\"]}],null,\\\"$L15\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"7:[\\\"$\\\",\\\"$1\\\",\\\"h\\\",{\\\"children\\\":[null,[[\\\"$\\\",\\\"$L16\\\",null,{\\\"children\\\":\\\"$L17\\\"}],null],[\\\"$\\\",\\\"$L18\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"hidden\\\":true,\\\"children\\\":[\\\"$\\\",\\\"$19\\\",null,{\\\"fallback\\\":null,\\\"children\\\":\\\"$L1a\\\"}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"1d:I[4431,[],\\\"OutletBoundary\\\"]\\n1f:I[5278,[],\\\"AsyncMetadataOutlet\\\"]\\n\"])</script><script>self.__next_f.push([1,\"d:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Ile kosztuje automatyzacja AI lub agent AI?\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-6 text-[#6b7280] leading-[1.7]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Koszty są bardzo zmienne. Prosta automatyzacja — np. wysyłanie e-maili powiadomień lub powiadomienia o nowych zapytaniach — może kosztować kilkaset złotych jako jednorazowa konfiguracja. Bardziej złożone systemy i agenci wymagają więcej pracy i kosztują więcej.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Kluczowe pytanie to nie „ile to będzie kosztować\\\\\\\", ale „ile ta automatyzacja mi zaoszczędzi\\\\\\\". Jeśli Twój zespół spędza 5 godzin tygodniowo na ręcznym sortowaniu e-maili, a automatyzacja to skraca do 30 minut — ta oszczędność szybko zwraca się z nawiązką.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Naszą rekomendacją jest zawsze zacząć z jednym procesem — tym, który marnuje Ci teraz najwięcej czasu. Zmierz wynik, zobacz korzyści, a potem rozwiń na kolejne obszary biznesu. W Getbuild nie namęcimy Cię na drogi system, jeśli prosty lepiej odpowiada Twoim potrzebom.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Zawsze najpierw mówimy o konkretnych liczbach, porównaniu nakładów do oszczędności i doradzimy, czy wdrożenie ma sens biznesowy dla Twojej firmy.\\\"}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"e:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Kiedy firma jest gotowa na automatyzacje AI?\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-6 text-[#6b7280] leading-[1.7]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Nie potrzebujesz być dużą firmą ani mieć wewnętrznych IT-owców. Automatyzacja AI ma sens dla każdej firmy, która ma powtarzalne zadania robione w ten sam sposób codziennie. Czy to jedna osoba, czy pięciu pracowników — jeśli spędzają czas na czynności, które można zautomatyzować, to jest potencjał.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Dobre punkty startowe: odpowiadanie na te same pytania od klientów w kółko, ręczne wysyłanie wiadomości po zamówieniu, kopiowanie danych z jednego systemu do drugiego, generowanie ofert lub protokołów, zarządzanie kalendarzem i umawianiem spotkań.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Pracujemy głównie z małymi i średnimi firmami usługowymi w Polsce — agentami nieruchomości, projektantami wnętrz, firmami budowlanymi, renowacyjnymi, usługami czyszczenia, doradcami prawnymi, doradcami finansowymi, producentami mebli. Żaden z nich nie miał wewnętrznego zespołu AI, ale wszystkim udało się automatyzować procesy, które im utrudniały życie.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Jeśli masz wątpliwości, czy coś się opłaca — zaproś nas do rozmowy. Często wystarczy 15 minut, żeby zobaczyć, czy automatyzacja ma sens w Twoim przypadku.\\\"}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"f:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Czy strona internetowa może być zintegrowana z automatyzacją AI?\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-6 text-[#6b7280] leading-[1.7]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Tak — i to jest właśnie tam, gdzie automatyzacja zazwyczaj zaczyna przynosić największą wartość. Strona internetowa to naturalny punkt wejścia dla automatyzacji.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Przykłady: formularz kontaktowy, który zamiast wysłać mejla do skrzynki, automatycznie kwalifikuje zapytanie i wysyła spersonalizowaną odpowiedź? Chat na stronie obsługiwany przez agenta AI, który odpowiada na pytania 24/7? System rezerwacji, który nie tylko ustawia spotkanie w kalendarzu, ale wysyła automatyczne przypomnienia i follow-upy?\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Budując stronę, możemy od razu zaprojektować ją w taki sposób, aby dobrze współpracowała z automatyzacją. To znaczy — formularz zbiera dokładnie te dane, które agent będzie musiał przeanalizować, a przepływ informacji jest płynny i nie wymaga ręcznego kopiowania.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"W Getbuild projektujemy stronę i automatyzacje razem, jako jeden spójny system — jeśli chcesz, aby Twoja strona nie tylko wyglądała dobrze, ale także pracowała dla Twojego biznesu.\\\"}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"10:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Ile kosztuje strona internetowa dla małej firmy?\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-6 text-[#6b7280] leading-[1.7]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"W Getbuild strony zaczynają się od około 150 zł miesięcznie, co obejmuje hosting, obsługę, aktualizacje bezpieczeństwa i bezpośrednie wsparcie. To znaczy — nie płacisz za stronę raz, ale za to, że Twoja strona zawsze działa, jest bezpieczna i wspierana.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Przed jakimikolwiek zobowiązaniami finansowymi tworzymy dla Ciebie bezpłatny projekt — wizualizację strony, którą widzisz przed opłaceniem czegokolwiek. To Ty decydujesz, czy projekt Ci się podoba i czy chcesz iść dalej.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Cena zawsze zależy od zakresu — mała strona dla fryzjera to inne pieniądze niż rozbudowany system dla firmy budowlanej. Zawsze omawiamy to szczegółowo, aby znaleźć rozwiązanie, które pasuje do Twojego budżetu.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Przesunięcia, zmiany i nowe funkcje możesz zlecać Adamowi w dowolnym momencie — e-mail, Instagram, rozmowa. Zmiany są wprowadzane bezpośrednio, bez dodatkowych umów czy zamówień.\\\"}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"11:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-6\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Ile czasu trwa stworzenie strony internetowej?\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-6 text-[#6b7280] leading-[1.7]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Podstawowa strona profesjonalna może być gotowa w ciągu 72 godzin od zebrania materiałów. To znaczy — jak dostarczysz nam teksty, zdjęcia i wiadomi, jakie informacje chcesz na stronie — w 3 dni projekt jest gotowy.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Bardziej złożone projekty zajmują więcej czasu. Ale najpierw robimy Ci bezpłatny mockup — wizualną koncepcję strony. Zatwierdzisz design, a potem wdrażamy.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Po uruchomieniu możesz w dowolnym momencie prosić o zmiany — Adam zajmie się nimi bezpośrednio.\\\"}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"12:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"relative bg-white py-12 md:py-20 px-6 md:px-12\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl text-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-[-0.03em] text-[#0A0A0F] mb-4\\\",\\\"style\\\":{\\\"fontFamily\\\":\\\"var(--font-syne)\\\"},\\\"children\\\":\\\"Masz pytanie o AI lub stronę WWW?\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-lg text-[#6b7280] mb-8\\\",\\\"children\\\":\\\"Odpiszę tego samego dnia. Umów bezpłatną 15-minutową rozmowę lub napisz bezpośrednio.\\\"}],[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"/#kontakt\\\",\\\"className\\\":\\\"inline-flex items-center gap-3 rounded-xl bg-[#2563EB] px-8 py-4 text-[15px] font-semibold text-white tracking-[-0.01em] transition-[background,box-shadow,transform] duration-200 hover:bg-[#1d4ed8] hover:shadow-[0 8px 24px rgba(37,99,235,0.20)] hover:-translate-y-0.5\\\",\\\"children\\\":\\\"Skontaktuj się\\\"}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"13:[[\\\"$\\\",\\\"$Lb\\\",null,{\\\"moduleIds\\\":[\\\"app\\\\\\\\wiedza-ai\\\\\\\\page.tsx -\\u003e @/components/Contact\\\"]}],\\\"$L1b\\\"]\\n14:[[\\\"$\\\",\\\"$Lb\\\",null,{\\\"moduleIds\\\":[\\\"app\\\\\\\\wiedza-ai\\\\\\\\page.tsx -\\u003e @/components/Footer\\\"]}],\\\"$L1c\\\"]\\n15:[\\\"$\\\",\\\"$L1d\\\",null,{\\\"children\\\":[\\\"$L1e\\\",[\\\"$\\\",\\\"$L1f\\\",null,{\\\"promise\\\":\\\"$@20\\\"}]]}]\\n\"])</script><script>self.__next_f.push([1,\"21:I[5325,[\\\"928\\\",\\\"static/chunks/928-11e5d014d184938c.js\\\",\\\"627\\\",\\\"static/chunks/627-24dfe8fef34572a9.js\\\",\\\"635\\\",\\\"static/chunks/635-8578d7cbb8df1f63.js\\\",\\\"96\\\",\\\"static/chunks/app/wiedza-ai/page-38e3445aee3f40d2.js\\\"],\\\"default\\\"]\\nc:[\\\"$\\\",\\\"$L21\\\",null,{}]\\n\"])</script><script>self.__next_f.push([1,\"22:I[9635,[\\\"928\\\",\\\"static/chunks/928-11e5d014d184938c.js\\\",\\\"627\\\",\\\"static/chunks/627-24dfe8fef34572a9.js\\\",\\\"635\\\",\\\"static/chunks/635-8578d7cbb8df1f63.js\\\",\\\"96\\\",\\\"static/chunks/app/wiedza-ai/page-38e3445aee3f40d2.js\\\"],\\\"default\\\"]\\n23:I[8743,[\\\"928\\\",\\\"static/chunks/928-11e5d014d184938c.js\\\",\\\"627\\\",\\\"static/chunks/627-24dfe8fef34572a9.js\\\",\\\"635\\\",\\\"static/chunks/635-8578d7cbb8df1f63.js\\\",\\\"96\\\",\\\"static/chunks/app/wiedza-ai/page-38e3445aee3f40d2.js\\\"],\\\"default\\\"]\\n1b:[\\\"$\\\",\\\"$L22\\\",null,{}]\\n1c:[\\\"$\\\",\\\"$L23\\\",null,{}]\\n\"])</script><script>self.__next_f.push([