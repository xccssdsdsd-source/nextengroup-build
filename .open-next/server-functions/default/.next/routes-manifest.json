{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/kontakt",
      "destination": "/#kontakt",
      "statusCode": 307,
      "regex": "^(?!/_next)/kontakt(?:/)?$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    },
    {
      "source": "/(.*)\\.(webp|png|jpg|ico|svg|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^(?:/(.*))\\.(webp|png|jpg|ico|svg|woff2)(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/agenci-ai",
      "regex": "^/agenci\\-ai(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/agenci\\-ai(?:/)?$"
    },
    {
      "page": "/audyt-seo",
      "regex": "^/audyt\\-seo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/audyt\\-seo(?:/)?$"
    },
    {
      "page": "/automatyzacje-ai",
      "regex": "^/automatyzacje\\-ai(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/automatyzacje\\-ai(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/polityka-prywatnosci",
      "regex": "^/polityka\\-prywatnosci(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/polityka\\-prywatnosci(?:/)?$"
    },
    {
      "page": "/realizacje",
      "regex": "^/realizacje(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/realizacje(?:/)?$"
    },
    {
      "page": "/realizacje/pm-apartments",
      "regex": "^/realizacje/pm\\-apartments(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/realizacje/pm\\-apartments(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/seo-dla-firm",
      "regex": "^/seo\\-dla\\-firm(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/seo\\-dla\\-firm(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/strony-internetowe-dla-firm",
      "regex": "^/strony\\-internetowe\\-dla\\-firm(?:/)?$",
      "routeKeys": {},
